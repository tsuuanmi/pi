{
	"compilerOptions": {
		"target": "ES2022",
		"module": "Node16",
		"lib": ["ES2022"],
		"strict": true,
		"erasableSyntaxOnly": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"inlineSources": true,
		"inlineSourceMap": false,
		"moduleResolution": "Node16",
		"resolveJsonModule": true,
		"allowImportingTsExtensions": true,
		"rewriteRelativeImportExtensions": true,
		"experimentalDecorators": true,
		"emitDecoratorMetadata": true,
		"useDefineForClassFields": false,
		"types": ["node"],
		"noEmit": true,
		"paths": {
			"*": ["./*"],
			"@tsuuanmi/pi-ai": ["./packages/ai/src/index.ts"],
			"@tsuuanmi/pi-ai/oauth": ["./packages/ai/src/oauth.ts"],
			"@tsuuanmi/pi-ai/*": ["./packages/ai/src/*.ts", "./packages/ai/src/providers/*.ts"],
			"@tsuuanmi/pi-ai/dist/*": ["./packages/ai/src/*"],
			"#ai/*": ["./packages/ai/src/*"],
			"#ai-test/*": ["./packages/ai/test/*"],
			"@tsuuanmi/pi-agent": ["./packages/agent/src/index.ts"],
			"@tsuuanmi/pi-agent/*": ["./packages/agent/src/*"],
			"#agent/*": ["./packages/agent/src/*"],
			"#agent-test/*": ["./packages/agent/test/*"],
			"@tsuuanmi/pi-coding-agent": ["./packages/coding-agent/src/index.ts"],
			"@tsuuanmi/pi-coding-agent/api/types": ["./packages/coding-agent/src/api/types.ts"],
			"@tsuuanmi/pi-coding-agent/core/config/config": ["./packages/coding-agent/src/core/config/config.ts"],
			"@tsuuanmi/pi-coding-agent/hooks": ["./packages/coding-agent/src/core/hooks/index.ts"],
			"@tsuuanmi/pi-coding-agent/*": ["./packages/coding-agent/src/*"],
			"#coding-agent/*": ["./packages/coding-agent/src/*"],
			"#coding-agent-test/*": ["./packages/coding-agent/test/*"],
			"typebox": ["./node_modules/typebox"],
			"@tsuuanmi/pi-tui": ["./packages/tui/src/index.ts"],
			"@tsuuanmi/pi-tui/test/virtual-terminal": ["./packages/tui/test/virtual-terminal.ts"],
			"@tsuuanmi/pi-tui/test/*": ["./packages/tui/test/*"],
			"@tsuuanmi/pi-tui/*": ["./packages/tui/src/*"],
			"#tui/*": ["./packages/tui/src/*"],
			"#tui-test/*": ["./packages/tui/test/*"],
			"@tsuuanmi/pi-agent-old": ["./packages/agent-old/src/index.ts"],
			"@tsuuanmi/pi-agent-old/*": ["./packages/agent-old/src/*"],
			"#workflows/*": ["./packages/workflows/src/*"]
		}
	},
	"include": ["packages/*/src/**/*", "packages/*/test/**/*"],
	"exclude": ["**/dist/**"]
}
