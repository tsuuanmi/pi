{
	"name": "@tsuuanmi/pi-agent",
	"version": "0.2.2",
	"description": "General-purpose agent with transport abstraction, state management, and attachment support",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js"
		},
		"./node": {
			"types": "./dist/node.d.ts",
			"import": "./dist/node.js"
		},
		"./package.json": "./package.json"
	},
	"imports": {
		"#agent/*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		},
		"#agent-test/*": {
			"types": "./test/*.ts",
			"import": "./test/*.ts"
		}
	},
	"files": [
		"dist",
		"README.md"
	],
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && node ./scripts/copy-schema-assets.mjs",
		"test": "vitest --run",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"dependencies": {
		"@tsuuanmi/pi-ai": "^0.2.2",
		"ignore": "7.0.5",
		"typebox": "1.1.38",
		"yaml": "2.9.0"
	},
	"keywords": [
		"ai",
		"agent",
		"llm",
		"transport",
		"state-management"
	],
	"author": "Superman",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tsuuanmi/pi.git",
		"directory": "packages/agent"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"devDependencies": {
		"@types/node": "24.12.4",
		"@vitest/coverage-v8": "3.2.6",
		"typescript": "5.9.3",
		"vitest": "3.2.6"
	}
}
