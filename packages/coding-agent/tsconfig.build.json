{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"outDir": "./dist",
		"paths": {
			"@tsuuanmi/pi-agent": ["../agent/dist/index.d.ts"],
			"@tsuuanmi/pi-agent/*": ["../agent/dist/*.d.ts"],
			"@tsuuanmi/pi-ai": ["../ai/dist/index.d.ts"],
			"@tsuuanmi/pi-ai/*": ["../ai/dist/*.d.ts", "../ai/dist/providers/*.d.ts"],
			"@tsuuanmi/pi-tui": ["../tui/dist/index.d.ts"],
			"@tsuuanmi/pi-tui/*": ["../tui/dist/*.d.ts", "../tui/dist/components/*.d.ts"],
			"@tsuuanmi/pi-workflows": ["../workflows/dist/index.d.ts"],
			"@tsuuanmi/pi-workflows/*": ["../workflows/dist/*.d.ts"]
		},
		"rootDir": "./src"
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts"],
	"exclude": ["node_modules", "dist"]
}
