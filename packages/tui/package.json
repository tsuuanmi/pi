{
	"name": "@tsuuanmi/pi-tui",
	"version": "0.2.2",
	"description": "Terminal User Interface library with differential rendering for efficient text-based applications",
	"type": "module",
	"os": [
		"darwin",
		"linux"
	],
	"main": "dist/index.js",
	"scripts": {
		"clean": "shx rm -rf dist",
		"build": "tsgo -p tsconfig.build.json && npm run copy-assets",
		"copy-assets": "shx mkdir -p dist/theme && shx cp src/theme/*.json dist/theme/",
		"test": "node --test \"test/**/*.test.ts\"",
		"prepublishOnly": "npm run clean && npm run build"
	},
	"files": [
		"dist/**/*",
		"README.md"
	],
	"keywords": [
		"tui",
		"terminal",
		"ui",
		"text-editor",
		"differential-rendering",
		"typescript",
		"cli"
	],
	"author": "Superman",
	"license": "MIT",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/tsuuanmi/pi.git",
		"directory": "packages/tui"
	},
	"engines": {
		"node": ">=22.19.0"
	},
	"types": "./dist/index.d.ts",
	"imports": {
		"#tui/*": {
			"types": "./dist/*.d.ts",
			"import": "./dist/*.js"
		},
		"#tui-test/*": {
			"types": "./test/*.ts",
			"import": "./test/*.ts"
		}
	},
	"dependencies": {
		"chalk": "5.6.2",
		"diff": "8.0.4",
		"get-east-asian-width": "1.6.0",
		"marked": "18.0.5",
		"typebox": "1.1.38",
		"highlight.js": "10.7.3"
	},
	"devDependencies": {
		"@xterm/headless": "5.5.0"
	}
}
