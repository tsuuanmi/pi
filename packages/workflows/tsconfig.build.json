{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"noEmit": false,
		"outDir": "./dist",
		"rootDir": "./src",
		"paths": {
			"#src/*": ["./src/*"],
			"@tsuuanmi/pi-coding-agent": ["../coding-agent/dist/index.d.ts"],
			"@tsuuanmi/pi-agent": ["../agent/dist/index.d.ts"],
			"@tsuuanmi/pi-agent/*": ["../agent/dist/*.d.ts"],
			"@tsuuanmi/pi-ai": ["../ai/dist/index.d.ts"],
			"@tsuuanmi/pi-ai/*": ["../ai/dist/*.d.ts", "../ai/dist/providers/*.d.ts"]
		}
	},
	"include": ["src/**/*.ts", "src/**/*.d.ts"],
	"exclude": ["node_modules", "dist"]
}